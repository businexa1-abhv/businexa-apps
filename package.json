{
  "name": "businexa",
  "private": true,
  "description": "Businexa monorepo — API, web, mobile, shared packages",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @businexa/api",
    "start:api": "npm run start -w @businexa/api",
    "test:api": "npm run test -w @businexa/api",
    "dev:web": "npm run dev -w @businexa/web",
    "build:web": "npm run build -w @businexa/web",
    "dev:mobile": "npm run start -w @businexa/mobile",
    "format": "npm run format -w @businexa/api"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
