# Copy to .env.businexaDev (gitignored). Loaded automatically for local development
# (NODE_ENV !== production and BUSINEXA_ENV unset → businexaDev).
#
# Full key list: see .env.example

BUSINEXA_ENV=businexaDev
NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000

# Same Atlas cluster is fine — use a separate DATABASE name per environment:
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/businexaDev

JWT_SECRET=dev-only-not-for-production
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Seed admin (npm run seed) — only when pointed at this DB
# SEED_ENABLED=true
# SEED_ADMIN_PASSWORD=change-this-min-8-chars
