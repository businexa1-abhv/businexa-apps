    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/send-otp",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"checkUserExists\": false\n}"
            },
            "url": "{{baseUrl}}/api/auth/send-otp"
          }
        },
        {
          "name": "POST /api/auth/verify-otp",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"seller\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/verify-otp"
          }
        },
        {
          "name": "POST /api/auth/refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "POST /api/auth/logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
