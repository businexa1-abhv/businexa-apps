{
  "name": "@businexa/api",
  "version": "1.0.0",
  "description": "Businexa QR advertisement platform — Node.js Express API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:prod": "cross-env BUSINEXA_ENV=businexaProd nodemon server.js",
    "seed": "node scripts/seed.js",
    "seed:prod": "cross-env BUSINEXA_ENV=businexaProd node scripts/seed.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "businexa",
    "express",
    "mongodb",
    "razorpay",
    "firebase"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@businexa/shared": "0.0.0",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  }
}
