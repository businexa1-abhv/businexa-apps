# Copy to .env.businexaProd (gitignored). Loaded when NODE_ENV=production or BUSINEXA_ENV=businexaProd.
# Use on the production host / CI — never commit real secrets.
#
# Full key list: see .env.example

BUSINEXA_ENV=businexaProd
NODE_ENV=production
PORT=5000
SERVER_URL=https://api.yourdomain.com

# Production database — different name (and often different Atlas user / IP allowlist):
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/businexaProd

# MUST differ from development — use a long random string:
JWT_SECRET=replace-with-long-random-secret

FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Production Razorpay live keys, SMTP, Firebase service account path, etc. — see .env.example
