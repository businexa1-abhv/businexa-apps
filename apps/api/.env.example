# --- Multi-environment (businexaDev / businexaProd) ---
# The API loads: (1) optional .env then (2) .env.<BUSINEXA_ENV> with override.
# Name resolution: BUSINEXA_ENV env var, else NODE_ENV=production → businexaProd, else → businexaDev.
# Copy .env.businexaDev.example → .env.businexaDev and .env.businexaProd.example → .env.businexaProd (both gitignored).
# Use different MONGODB_URI database names (e.g. .../businexaDev vs .../businexaProd) on the same or different clusters.
# Scripts: npm run dev (dev env), npm run dev:prod (run locally with prod env file), npm run seed:prod (seed prod DB — use carefully).

# Server
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
# SHUTDOWN_TIMEOUT_MS=15000
SERVER_URL=http://localhost:5000

# Database — the path segment after the host is the DATABASE name (e.g. businexaDev).
# If you use ...mongodb.net/?options with no DB name, the driver defaults to "test", and Data Explorer will show data only under database "test", not under other names you see in the tree.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/businexa
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Seed — JWT admins from apps/api/scripts/admins.seed.json (npm run seed)
# SEED_ENABLED=true
# Shared password for every admin in the JSON (default Harsha@1234 if unset)
# SEED_ADMINS_PASSWORD=Harsha@1234

# Logging (Winston — src/config/logger.js)
# LOG_LEVEL=debug
# LOG_SERVICE_NAME=businexa-api
# LOG_FILE=logs/app.log
# LOG_MAX_FILE_BYTES=5242880
# LOG_MAX_FILES=3

# Firebase Admin SDK (project: businexa)
# Recommended: save the JSON from Firebase Console as firebase-service-account.json (gitignored) and set:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Optional default bucket name (often <project_id>.appspot.com):
# FIREBASE_STORAGE_BUCKET=businexa.appspot.com
#
# Alternative — inline .env (one line for FIREBASE_PRIVATE_KEY with \n between PEM lines):
# FIREBASE_PROJECT_ID=businexa
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@businexa.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Skip Firebase during dev: SKIP_FIREBASE_INIT=true

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_SECRET=rzp_live_secret_xxxxx

# JWT — required for POST /auth/register and /auth/login (username + password). Use a long random secret in production.
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRY=7d

# Password reset — link in email uses FRONTEND_URL + /reset-password?token=...
# PASSWORD_RESET_EXPIRY_MINUTES=60
# Dev only: include resetUrl in JSON when user has no email or SMTP is off (never enable in production)
# PASSWORD_RESET_DEV_LINK=false

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Fixed test OTP (development / QA) — same flow as production, then Firebase custom token.
# Numbers must be 10-digit Indian. Admin role: also list the number in ADMIN_MOBILE_NUMBERS (first signup only).
# Buyer vs seller: open /verify-otp?role=buyer or ?role=seller after Send OTP (default seller).
# In production, fixed OTP is ignored unless ALLOW_TEST_OTP_IN_PROD=true (not recommended).
TEST_OTP_ENABLED=false
TEST_OTP_CODE=123499
TEST_OTP_MOBILES=9440544752,9959212349
# ALLOW_TEST_OTP_IN_PROD=false

# MSG91 — SMS OTP (India). Leave disabled until you are ready; default is Firebase + dev-console OTP only.
MSG91_ENABLED=false
# Dashboard: https://control.msg91.com/ → Settings → Authkey
# DLT: register a transactional template with ##OTP## and paste the exact approved text into MSG91_MESSAGE.
MSG91_AUTHKEY=
# 6-character approved Sender ID (e.g. BUSINX)
MSG91_SENDER_ID=OTPSMS
# Must match your DLT-approved template; ##OTP## is replaced by MSG91
# MSG91_MESSAGE=Your Businexa verification code is ##OTP##. Do not share it with anyone.
# MSG91_OTP_EXPIRY_MINUTES=10

# Roles — optional; comma-separated 10-digit Indian mobiles (e.g. 9876543210,9123456789).
# Listed numbers receive MongoDB role `admin` on first signup only (not via verify-otp JSON body).
ADMIN_MOBILE_NUMBERS=

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,https://businexa.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@businexa.com
SMTP_PASSWORD=app-password

# Cloud Storage — AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxxx
AWS_SECRET_ACCESS_KEY=xxxx
AWS_S3_BUCKET=businexa-products
# Optional: public base if URL differs (e.g. CloudFront). Default: https://{bucket}.s3.{region}.amazonaws.com
# AWS_S3_PUBLIC_BASE_URL=https://cdn.example.com

# Cloudinary (alternative)
CLOUDINARY_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# Frontend
FRONTEND_URL=http://localhost:3000
FRONTEND_MOBILE_URL=exp://localhost:19000

# Analytics
ENABLE_ANALYTICS=true
