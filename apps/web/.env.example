# --- Match API environment (businexaDev vs businexaProd) ---
# Next.js loads by mode: `next dev` → .env.development, .env.local; `next build` / `next start` → .env.production, .env.local
# Recommended: copy this file to .env.development.local (local dev → localhost API) and .env.production.local (deploy → prod API URL).
# Do not commit *.local files — they are usually gitignored.

# Public API base (no trailing slash) — dev:
NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Production example: https://api.yourdomain.com/api

# Must match apps/api OTP_LENGTH (default 6). Set if API uses a non-default OTP_LENGTH.
# NEXT_PUBLIC_OTP_LENGTH=6

# Firebase web client (same project as API Firebase Admin)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD5v3LCnsjWwX4PP0GHxww4gUMPY4MSmPI
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=businexa.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=businexa
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=businexa.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=944142993651
NEXT_PUBLIC_FIREBASE_APP_ID=1:944142993651:web:f91bcb66eddde3135d0f86

# Used for canonical URLs in SEO metadata (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
